# ============================================================
# Google Sheets Configuration
# ============================================================
# Path to Google Service Account credentials JSON file
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Sheet ID (from the sheet URL)
# Example: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
SHEET_ID=1MxWwbZhmwhI-1b35KN42ocMusQoycee3zU0dGnm58eA

# Sheet tab name (ten cua tab trong sheet)
SHEET_NAME=未表示Yahooサジェスト一覧

# ============================================================
# User Configuration
# ============================================================
# Ten nhan vien (phai trung voi ten trong sheet, vd: VO DINH TIEN)
USER_NAME=HUYNH KHAC HOAI NAM

# ============================================================
# Browser Configuration
# ============================================================
# Duong dan den file thuc thi cua Edge
EDGE_EXECUTABLE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe

# Thu muc du lieu nguoi dung (chua tat ca profile)
# Vi du: C:\Users\TenUser\AppData\Local\Microsoft\Edge\User Data
EDGE_USER_DATA_DIR=C:\Users\YourName\AppData\Local\Microsoft\Edge\User Data

# Ten thu muc profile muon su dung (Default, Profile 1, Profile 2, ...)
EDGE_PROFILE_DIRECTORY=Default

# Cong remote debugging - script tu dong kiem tra va mo Edge neu chua chay
EDGE_REMOTE_DEBUGGING_PORT=9222

# CDP URL (tu dong tao tu port, thuong khong can sua)
EDGE_CDP_URL=http://localhost:9222

# ============================================================
# Mobile User Agent (dung cho che do PC(UA:SP))
# ============================================================
MOBILE_USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 18_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) EdgiOS/117.0 Mobile/15E148 Safari/605.1.15
